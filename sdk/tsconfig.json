{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "declaration": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@velum/sdk": ["./src/index.ts"]
    }
  },
  "include": ["src/**/*", "examples/**/*"]
}
