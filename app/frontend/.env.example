# ---------------------------------------------------------------------------
# Velum frontend environment
#
# The frontend gets almost all of its config from the backend at runtime:
# contract addresses, RPC URL and chain id come from GET /api/config, and the
# WETH token address arrives inside the balance responses. The ONLY thing the
# frontend needs to know on its own is WHERE the backend lives.
# ---------------------------------------------------------------------------

# Public base URL of the Velum backend API.
#   - Local dev: leave this unset — the code falls back to http://localhost:3001.
#   - Production (Vercel): REQUIRED. Point it at your deployed backend (Railway).
#
# Notes:
#   - NEXT_PUBLIC_* vars are inlined into the bundle at BUILD time, so set this
#     in Vercel BEFORE building (a later change needs a redeploy to take effect).
#   - No trailing slash — the code concatenates `${NEXT_PUBLIC_API_URL}/api/...`.
#   - Must be reachable from the browser (https), and the backend's CORS_ORIGIN
#     must include this frontend's URL.
NEXT_PUBLIC_API_URL=http://localhost:3001
