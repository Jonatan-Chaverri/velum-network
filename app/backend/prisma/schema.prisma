generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PricingModel {
  per_request
  subscription
}

enum BillingUnit {
  response
  month
}

enum ServiceStatus {
  online
  offline
}

enum InvoiceStatus {
  pending
  paid
  expired
  cancelled
  failed
}

enum TransactionType {
  deposit
  transfer
  withdraw
}

enum TransactionStatus {
  pending
  confirmed
  failed
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  lastName     String    @map("last_name")
  organization String?
  email        String    @unique
  password     String
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  sessions     Session[]
  agents       Agent[]

  @@map("users")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  accessTokenJti   String    @map("access_token_jti")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  lastUsedAt       DateTime? @map("last_used_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  ipAddress        String?   @map("ip_address") @db.Inet
  userAgent        String?   @map("user_agent")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accessTokenJti])
  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("sessions")
}

model Agent {
  id                   String        @id @default(uuid()) @db.Uuid
  agentId              BigInt        @unique @default(autoincrement()) @map("agent_id")
  userId               String        @map("user_id") @db.Uuid
  title                String
  description          String
  category             String
  publicKey            String        @map("public_key")
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  services             Service[]
  sellerInvoices       Invoice[]     @relation("SellerInvoices")
  buyerInvoices        Invoice[]     @relation("BuyerInvoices")
  sentTransactions     Transaction[] @relation("SenderAgentTransactions")
  receivedTransactions Transaction[] @relation("ReceiverAgentTransactions")

  @@index([userId])
  @@map("agents")
}

model AgentReputation {
  id               String   @id @default(uuid()) @db.Uuid
  serviceId        String   @unique @map("service_id") @db.Uuid
  successResponses Int      @default(0) @map("success_responses")
  totalRequests    Int      @default(0) @map("total_requests")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  service          Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("agents_reputation")
}

model Service {
  id           String           @id @default(uuid()) @db.Uuid
  agentId      String           @map("agent_id") @db.Uuid
  price        Decimal          @db.Decimal(18, 6)
  pricingModel PricingModel     @map("pricing_model")
  currency     String
  billingUnit  BillingUnit      @map("billing_unit")
  endpointUrl  String           @map("endpoint_url")
  status       ServiceStatus
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  agent        Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  reputation   AgentReputation?

  @@index([agentId])
  @@map("services")
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  sellerAgentId String        @map("seller_agent") @db.Uuid
  buyerAgentId  String        @map("buyer_agent") @db.Uuid
  amount        Decimal       @db.Decimal(18, 6)
  currency      String
  status        InvoiceStatus
  expiresAt     DateTime      @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  paidAt        DateTime?     @map("paid_at") @db.Timestamptz(6)
  txHash        String?       @map("tx_hash")
  sellerAgent   Agent         @relation("SellerInvoices", fields: [sellerAgentId], references: [id], onDelete: Cascade)
  buyerAgent    Agent         @relation("BuyerInvoices", fields: [buyerAgentId], references: [id], onDelete: Cascade)

  @@index([sellerAgentId])
  @@index([buyerAgentId])
  @@index([status])
  @@map("invoices")
}

model Transaction {
  id               String            @id @default(uuid()) @db.Uuid
  txHash           String            @unique @map("tx_hash")
  type             TransactionType
  status           TransactionStatus
  token            String?
  amount           String?
  senderAgentId    String?           @map("sender_agent_id") @db.Uuid
  receiverAgentId  String?           @map("receiver_agent_id") @db.Uuid
  associatedWallet String?           @map("associated_wallet")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  senderAgent      Agent?            @relation("SenderAgentTransactions", fields: [senderAgentId], references: [id], onDelete: SetNull)
  receiverAgent    Agent?            @relation("ReceiverAgentTransactions", fields: [receiverAgentId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([status])
  @@index([senderAgentId])
  @@index([receiverAgentId])
  @@index([createdAt])
  @@map("transactions")
}
