
PORT=3001
CORS_ORIGIN=http://localhost:3000

DATABASE_URL=
DIRECT_URL=
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

RPC_URL=http://localhost:8547
ACCOUNT_PRIVATE_KEY=0x...

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

NETWORK=SEPOLIA

# On-chain contract addresses (resolved from env, not the DB)
CONFIDENTIAL_ERC20_ADDRESS=0x...
WETH_TOKEN_ADDRESS=0x...
# ERC-8004 IdentityRegistry (Arbitrum Sepolia) — agents are auto-registered here on creation
ERC8004_IDENTITY_REGISTRY=0xCf0C9f0Bfd29B73c85351b61b5a758ba1E1ea2D9
# Public base URL of this API (used as the base for ERC-8004 agent card tokenURIs)
PUBLIC_API_URL=http://localhost:3001

# SDK API keys (capability tokens). API_KEY_SIGNING_SECRET signs/validates the
# HMAC; PROVER_SEALING_KEY decrypts sealed agent keys — only the prover worker
# ever uses it. Generate both with: openssl rand -hex 32
API_KEY_SIGNING_SECRET=
PROVER_SEALING_KEY=
# Optional override for the compiled transfer circuit used by the prover
# (defaults to ../../wallet_proof/target/transfer.json relative to the backend)
# TRANSFER_CIRCUIT_PATH=
